{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "completion": {
    "autoRequire": true,
    "autoRequireFunction": "require",
    "autoRequireNamingConvention": "snake-case",
    "callSnippet": true,
    "postfix": "@"
  },
  "signature": {
    "detailSignatureHelper": true
  },
  "diagnostics": {
    "disable": [],
    "globals": ["vim", "nyagos", "Snacks"],
    "globalsRegex": [],
    "severity": {},
    "enables": []
  },
  "hint": {
    "paramHint": true,
    "indexHint": true,
    "localHint": true,
    "overrideHint": true
  },
  "runtime": {
    "version": "LuaJIT",
    "requireLikeFunction": [],
    "frameworkVersions": [],
    "extensions": [],
    "requirePattern": ["?.lua", "?/init.lua", "?/types.lua"]
  },
  "workspace": {
    "ignoreDir": [],
    "ignoreGlobs": [],
    "library": [],
    "workspaceRoots": [".git", ".emmyrc.json", "stylua.toml"],
    "preloadFileSize": 1048576,
    "encoding": ""
  },
  "resource": {
    "paths": []
  },
  "codeLens": {
    "enable": true
  },
  "strict": {
    "requirePath": false,
    "typeCall": true
  }
}
